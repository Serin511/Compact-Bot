{
  "name": "claude-discord-bot",
  "version": "0.1.0",
  "description": "Discord bot powered by Claude Code CLI subprocess",
  "type": "module",
  "main": "dist/wrapper.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/wrapper.js",
    "start:legacy": "node dist/index.js",
    "dev": "tsx src/wrapper.ts",
    "dev:legacy": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@slack/socket-mode": "^2.0.6",
    "@slack/web-api": "^7.15.0",
    "chalk": "^5.6.2",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}

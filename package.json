{
  "name": "@serin511/compact-bot",
  "version": "1.1.3",
  "description": "Multi-platform chat bot (Discord + Slack) powered by Claude Code MCP channels",
  "type": "module",
  "main": "dist/wrapper.js",
  "bin": {
    "compact-bot": "dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map"
  ],
  "scripts": {
    "postinstall": "node -e \"try{require('fs').chmodSync(require('path').join('node_modules','node-pty','prebuilds',process.platform+'-'+process.arch,'spawn-helper'),0o755)}catch{}\"",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/wrapper.js",
    "dev": "tsx src/wrapper.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "claude",
    "discord",
    "slack",
    "chatbot",
    "mcp",
    "claude-code"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Serin511/Claude-Discord-Bot.git"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@slack/socket-mode": "^2.0.6",
    "@slack/web-api": "^7.15.0",
    "@xterm/headless": "^6.0.0",
    "chalk": "^5.6.2",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}

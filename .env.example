# [플랫폼 토큰] Discord / Slack 중 최소 하나는 필수
DISCORD_BOT_TOKEN=your_discord_bot_token_here
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token

# Verbose — Claude Code 터미널 출력 및 MCP 서버 로그를 콘솔에 출력
VERBOSE=false

# Defaults
# DEFAULT_MODEL=sonnet  # 미지정 시 CLI 기본 모델 사용. alias(sonnet/opus/haiku)도 그대로 전달됨
# DEFAULT_CWD=~/  # 미지정 시 현재 폴더(cwd) 사용
MAX_TURNS=0                 # 0 = unlimited
FETCH_MESSAGE_LIMIT=20      # 0 = max (500)
ALLOWED_CHANNEL_IDS=
SLACK_ALLOWED_CHANNEL_IDS=

# Path to Claude Code CLI (defaults to "claude" from PATH)
# CLAUDE_PATH=claude

# --dangerously-skip-permissions 플래그 사용 여부
# DANGEROUSLY_SKIP_PERMISSIONS=true

# Claude Code 2.1.x에서는 `--mcp-config`로 등록한 채널 서버의 툴이
# 세션에 노출되지 않는 회귀가 있어, 기본값으로 `claude mcp add-json`을
# 사용해 로컬 스코프에 사전 등록합니다. 최신 CLI에서 수정됐다면 true로
# 설정해 CWD 오염을 피할 수 있습니다.
# SKIP_MCP_REGISTRATION=false

# PTY 크기 (Claude Code Ink UI 렌더링 영역)
# PTY_COLS=200
# PTY_ROWS=50

# Optional system prompt file
# SYSTEM_PROMPT_PATH=data/system-prompt.txt
